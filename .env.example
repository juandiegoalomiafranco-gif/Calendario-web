# Copia este archivo a .env y rellena con los valores de tu proyecto Supabase.
# Los encuentras en el botón "Connect" del panel, o en Settings → API Keys.
# Solo valores PÚBLICOS aquí — nunca la secret key (sb_secret_...).
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_XXXXXXXXXXXX
